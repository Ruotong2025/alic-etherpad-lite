      "estimated_duration": "10-20分钟",
      "log_file": "pad-info.log"
    },
    "pad_version_incremental": {
      "cron": "0 5 * * *",
      "command": "--process-incremental-etherpad_pad_version",
      "description": "Pad版本增量处理",
      "target_table": "etherpad_pad_version",
      "priority": 3,
      "estimated_duration": "30-60分钟",
