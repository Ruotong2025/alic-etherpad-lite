{
  "enabled": true,
  "timezone": "Asia/Shanghai",
  "task_schedules": {
    "author_data_sync": {
      "cron": "0 4 * * *",
      "command": "--process-etherpad_author",
      "description": "作者信息全量更新",
      "target_table": "etherpad_author",
      "priority": 1,
      "estimated_duration": "10-30分钟",
      "log_file": "author-sync.log"
    },
    "pad_info_extraction": {
      "cron": "30 4 * * *",
      "command": "--process-etherpad_pad_info",
      "description": "Pad基础信息提取",
      "target_table": "etherpad_pad_info",
      "priority": 2,
      "estimated_duration": "10-20分钟",
      "log_file": "pad-info.log"
    }
  },
  "execution_flow": {
    "description": "每日凌晨自动执行数据同步任务",
    "sequence": [
      {
        "step": 1,
        "time": "04:00",
        "task": "author_data_sync",
        "purpose": "全量同步作者信息到 etherpad_author 表"
      },
      {
        "step": 2,
        "time": "04:30",
        "task": "pad_info_extraction",
        "purpose": "全量提取 Pad 基础信息到 etherpad_pad_info 表"
      }
    ]
  }
}
